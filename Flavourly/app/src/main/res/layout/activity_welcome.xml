<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_mesh_dark"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/content_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="124dp"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:letterSpacing="0.04"
            android:text="Midnight Kitchen Crisis"
            android:textColor="#0631D0"
            android:textSize="50sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The Assistant You’ll Regret Trusting"
            android:textSize="18sp"
            android:textColor="#E0E0E0"
            android:gravity="center"
            android:layout_marginBottom="48dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="26dp"
            app:cardElevation="10dp"
            app:strokeWidth="1dp"
            app:strokeColor="#20FFFFFF"
            android:backgroundTint="#1AFFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSign_up"
                    android:layout_width="match_parent"
                    android:layout_height="124dp"
                    android:backgroundTint="@color/black"
                    android:elevation="6dp"
                    android:text="Sign Up"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:text="Login"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:textColor="@color/purple_500"
                    android:textStyle="bold"
                    app:cornerRadius="18dp"
                    app:strokeColor="#40FFFFFF"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>