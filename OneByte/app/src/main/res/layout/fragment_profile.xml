<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ProfileFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/baseline_calendar_month_24"
                    android:padding="3dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/baseline_person_24"
                    android:translationZ="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/nameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp"
                    android:layout_marginStart="20dp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.133"
                    app:layout_constraintStart_toEndOf="@id/imageView"
                    app:layout_constraintTop_toTopOf="@id/imageView" />

                <TextView
                    android:id="@+id/studentText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="St"
                    android:layout_marginStart="20dp"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnSurface"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/imageView"
                    app:layout_constraintTop_toBottomOf="@id/nameText"
                    app:layout_constraintBottom_toBottomOf="@id/imageView"/>


                <View
                    android:id="@+id/view"
                    android:layout_width="0dp"
                    android:layout_height="0.8dp"
                    android:layout_marginTop="24dp"
                    android:background="@color/white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/imageView" />

                <TextView
                    android:id="@+id/contactText"
                    android:layout_width="382dp"
                    android:layout_height="wrap_content"
                    android:text="Concat Dial"
                    android:textColor="@color/red"
                    android:textSize="78sp"
                    app:layout_constraintBottom_toTopOf="@+id/phoneImage"
                    app:layout_constraintTop_toBottomOf="@+id/imageView"
                    app:layout_constraintVertical_bias="0.32"
                    tools:layout_editor_absoluteX="3dp" />

                <ImageView
                    android:id="@+id/emailImage"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginTop="96dp"
                    android:src="@drawable/baseline_email_24"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/contactText" />

                <TextView
                    android:id="@+id/emailtextHeading"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="268dp"
                    android:layout_marginTop="-5dp"
                    android:text="Name"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/emailImage"
                    app:layout_constraintTop_toTopOf="@id/emailImage" />

                <TextView
                    android:id="@+id/emailText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="-5dp"
                    android:text=""
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/emailImage"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1.0"
                    app:layout_constraintStart_toEndOf="@id/emailImage"
                    app:layout_constraintTop_toBottomOf="@id/emailtextHeading"
                    app:layout_constraintVertical_bias="0.0" />

                <ImageView
                    android:id="@+id/phoneImage"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/baseline_phone_24"
                    tools:layout_editor_absoluteX="225dp"
                    tools:layout_editor_absoluteY="475dp" />

                <TextView
                    android:id="@+id/phonetextHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="-5dp"
                    android:text="Phone"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/phoneImage"
                    app:layout_constraintTop_toTopOf="@id/phoneImage" />

                <TextView
                    android:id="@+id/phoneText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text=""
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:layout_marginBottom="-5dp"
                    app:layout_constraintBottom_toBottomOf="@id/phoneImage"
                    app:layout_constraintStart_toEndOf="@id/phoneImage"
                    app:layout_constraintTop_toBottomOf="@id/phonetextHeading"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/personalText"
                    android:layout_width="382dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="132dp"
                    android:text="Question 3 "
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="italic"
                    app:layout_constraintBottom_toTopOf="@+id/phoneImage"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/contactText"
                    app:layout_constraintVertical_bias="1.0" />

                <ImageView
                    android:id="@+id/ageImage"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/baseline_check_circle_24"
                    app:layout_constraintEnd_toEndOf="@+id/ageText"
                    app:layout_constraintTop_toBottomOf="@+id/emailImage" />

                <TextView
                    android:id="@+id/agetextHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="80dp"
                    android:layout_marginTop="-5dp"
                    android:text="Age"
                    android:textColor="@color/blue"
                    android:textSize="28sp"
                    app:layout_constraintStart_toEndOf="@id/ageImage"
                    app:layout_constraintTop_toTopOf="@id/ageImage" />

                <TextView
                    android:id="@+id/ageText"
                    android:layout_width="330dp"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    app:layout_constraintTop_toBottomOf="@+id/contactText"
                    tools:layout_editor_absoluteX="40dp" />

                <ImageView
                    android:id="@+id/stateImage"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginTop="30dp"
                    app:layout_constraintTop_toBottomOf="@id/ageImage"
                    app:layout_constraintStart_toStartOf="parent"
                    android:src="@drawable/baseline_person_24"/>

                <TextView
                    android:id="@+id/statetextHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="-5dp"
                    android:text="State"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/stateImage"
                    app:layout_constraintTop_toTopOf="@id/stateImage"/>

                <TextView
                    android:id="@+id/stateText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="-5dp"
                    android:text=""
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/stateImage"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1.0"
                    app:layout_constraintStart_toEndOf="@id/stateImage"
                    app:layout_constraintTop_toBottomOf="@id/statetextHeading"
                    app:layout_constraintVertical_bias="1.0" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>